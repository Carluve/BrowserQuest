{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "browserquest",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./assets",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "WORLD", "class_name": "WorldDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["WorldDO"] }
  ],
  "observability": {
    "enabled": true
  }
}
